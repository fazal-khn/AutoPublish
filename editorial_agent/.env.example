# Gemini API Key (Get it from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Ayrshare API Key (Get it from Ayrshare.com - Free Tier handles multiple social networks)
AYRSHARE_API_KEY=your_ayrshare_api_key_here

# Provide a publicly accessible URL path where your images are hosted, 
# or a folder path if uploading directly (Ayrshare supports both, but public URLs are often easier for automated pipelines).
# For GitHub Actions, you can store images in a 'portfolio' folder in the repo.
